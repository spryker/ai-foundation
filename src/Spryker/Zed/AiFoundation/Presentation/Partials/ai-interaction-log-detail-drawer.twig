<div class="offcanvas offcanvas-end detail-drawer"
    tabindex="-1" id="detail-drawer"
    aria-labelledby="ai-interaction-log-details"
    data-failed-message="{{ 'Failed to load information' | trans }}">
  <div class="offcanvas-header">
    <h5 class="offcanvas-title" id="ai-interaction-log-details">{{ 'Interaction Detail' | trans }}</h5>
    <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>
  <div id="drawer-content" class="offcanvas-body">
    <div class="text-center text-muted">{{ 'Loading...' | trans }}</div>
  </div>
</div>