<?xml version="1.0"?>
<database xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://static.spryker.com/schema-01.xsd" name="zed" namespace="Orm\Zed\AiFoundation\Persistence" package="src.Orm.Zed.AiFoundation.Persistence">

    <table name="spy_ai_conversation_history" idMethod="native" allowPkInsert="true">
        <column name="id_ai_conversation_history" required="true" type="INTEGER" primaryKey="true" autoIncrement="true"/>
        <column name="conversation_reference" required="true" type="VARCHAR" size="255" description="Unique identifier for a conversation thread."/>
        <column name="original_messages" required="true" type="LONGVARCHAR" description="JSON-encoded array of raw messages."/>

        <behavior name="timestampable"/>

        <id-method-parameter value="spy_ai_conversation_history_pk_seq"/>

        <unique name="spy_ai_conversation_history-unique-conversation_reference">
            <unique-column name="conversation_reference"/>
        </unique>

        <index name="spy_ai_conversation_history-conversation_reference">
            <index-column name="conversation_reference"/>
        </index>
    </table>

</database>
