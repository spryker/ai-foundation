{
    "name": "spryker/ai-foundation",
    "type": "library",
    "description": "AiFoundation module",
    "license": "proprietary",
    "require": {
        "aws/aws-sdk-php": "^3.209",
        "neuron-core/neuron-ai": "^2.9.3",
        "php": ">=8.3",
        "spryker/gui": "^5.0.1",
        "spryker/kernel": "^3.30.0",
        "spryker/log-extension": "^1.0.0",
        "spryker/monolog": "^2.0.5",
        "spryker/propel-orm": "^1.15.0",
        "spryker/state-machine": "^2.0.0",
        "spryker/symfony": "^3.0.0",
        "spryker/transfer": "^3.27.0",
        "spryker/util-text": "^1.0.0",
        "spryker/zed-request": "^3.20.0"
    },
    "require-dev": {
        "spryker/code-sniffer": "*",
        "spryker/log": "*",
        "spryker/propel": "*",
        "spryker/testify": "*"
    },
    "suggest": {
        "spryker/log": "Provides logging infrastructure and audit log support for Spryker features."
    },
    "autoload": {
        "psr-4": {
            "Spryker\\": "src/Spryker/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SprykerTest\\": "tests/SprykerTest/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "cs-check": "phpcs -p -s --standard=vendor/spryker/code-sniffer/SprykerStrict/ruleset.xml src/ tests/",
        "cs-fix": "phpcbf -p --standard=vendor/spryker/code-sniffer/SprykerStrict/ruleset.xml src/ tests/"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
